# === REQUIRED ===
MOLTGUARD_WALLET=0x...              # Base-Wallet das USDC empfängt (x402 payTo)
BASE_RPC_URL=https://mainnet.base.org

# === OPTIONAL ===
PORT=3000
FACILITATOR_URL=https://facilitator.x402.org
ERC8004_REGISTRY=0x...              # ERC-8004 Registry Contract auf Base (wenn verfügbar)
POLYMARKET_API=https://clob.polymarket.com
POLYMARKET_GAMMA_API=https://gamma-api.polymarket.com
RATE_LIMIT_WINDOW_MS=600000         # 10 Minuten
RATE_LIMIT_MAX_FREE=1               # 1 Free-Request pro Window
NODE_ENV=production
